{
    "name": "Kotlin Dev Environment",
    "image": "mcr.microsoft.com/devcontainers/java:1-17-bullseye",
    "customizations": {
        "vscode": {
            "extensions": [
                "fwcd.kotlin",
                "formulahendry.code-runner"
            ]
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y kotlin"
}
